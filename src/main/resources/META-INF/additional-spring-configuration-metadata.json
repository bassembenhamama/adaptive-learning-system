{
  "properties": [
    {
      "name": "app.jwt.secret",
      "type": "java.lang.String",
      "description": "JWT Secret Key."
    },
    {
      "name": "app.jwt.expiration-ms",
      "type": "java.lang.Long",
      "description": "JWT Expiration time in milliseconds."
    },
    {
      "name": "app.upload.dir",
      "type": "java.lang.String",
      "description": "Directory path for storing uploaded files (videos, PDFs).",
      "defaultValue": "./uploads"
    }
  ]
}
